{
  "name": "dragmate-server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Authoritative game backend for DragMate (chess, backgammon, okey, 101) over Socket.IO",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "chess.js": "^1.4.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "socket.io": "^4.8.1",
    "tsx": "^4.20.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^24.10.1",
    "typescript": "~5.9.3"
  }
}
